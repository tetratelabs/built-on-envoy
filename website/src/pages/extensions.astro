---
import { PROJECT_NAME } from '../constants';
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ExtensionCard from '../components/ExtensionCard.astro';
import { loadExtensions } from '../utils/extensions';
import '../styles/extensions.css';

const extensions = loadExtensions();

// Collect unique types from extensions and sort alphabetically
const sortedTypes = [...new Set(extensions.map(ext => ext.type))]
	.sort((a, b) => a.localeCompare(b));

// Collect unique categories from extensions and sort alphabetically
const sortedCategories = [...new Set(extensions.flatMap(ext => ext.categories))]
	.sort((a, b) => a.localeCompare(b));

// Helper function to format type names (snake_case to Title Case)
function formatTypeName(type: string): string {
	return type
		.split('_')
		.map(word => word.charAt(0).toUpperCase() + word.slice(1))
		.join(' ');
}
---

<!DOCTYPE html>
<html lang="en">
	<Head
		title={`Extension Catalog - ${PROJECT_NAME}`}
		description={`Browse all available extensions for Envoy Proxy in the ${PROJECT_NAME} marketplace`}
		preventFOUC={true}
	/>
	<body>
		<Header />

		<main>
			<section class="page-hero">
				<div class="container">
					<h1>Extension Catalog</h1>
					<p class="hero-subtitle">
						Discover {extensions.length} community and officially maintained extensions for Envoy® Proxy
					</p>

					<div class="filters">
						<div class="search-box">
							<input
								type="text"
								id="search-input"
								placeholder="Search by name, description, or tags..."
								aria-label="Search extensions"
							/>
						</div>
						<div class="category-filter">
							<select id="category-filter" aria-label="Filter by category">
								<option value="">All Categories</option>
								{sortedCategories.map(category => (
									<option value={category}>{category}</option>
								))}
							</select>
						</div>
						<div class="type-filter">
							<select id="type-filter" aria-label="Filter by type">
								<option value="">All Types</option>
								{sortedTypes.map(type => (
									<option value={type}>{formatTypeName(type)}</option>
								))}
							</select>
						</div>
					</div>
				</div>
			</section>

			<section class="extensions-catalog">
				<div class="container">
					{extensions.length > 0 ? (
						<>
							<div class="extensions-grid" id="extensions-grid">
								{extensions.map(ext => (
									<div data-categories={ext.categories.join(',')}>
										<ExtensionCard
											name={ext.name}
											type={ext.type}
											description={ext.description}
											href={`/extensions/${ext.name}`}
											tags={ext.tags}
										/>
									</div>
								))}
							</div>
							<div class="empty-state" id="no-results" style="display: none;">
								<p>No extensions found matching your search.</p>
							</div>
						</>
					) : (
						<div class="empty-state">
							<p>No extensions found. Check back soon!</p>
						</div>
					)}
				</div>
			</section>
		</main>

		<Footer />

		<script>
			// Prevent FOUC
			document.body.classList.add('loaded');

			// Extension filtering functionality
			const searchInput = document.getElementById('search-input') as HTMLInputElement;
			const typeFilter = document.getElementById('type-filter') as HTMLSelectElement;
			const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement;
			const extensionsGrid = document.getElementById('extensions-grid');
			const noResults = document.getElementById('no-results');

			function filterExtensions() {
				const searchTerm = searchInput?.value.toLowerCase() || '';
				const selectedType = typeFilter?.value || '';
				const selectedCategory = categoryFilter?.value || '';

				const cardWrappers = extensionsGrid?.querySelectorAll('[data-categories]');
				let visibleCount = 0;

				cardWrappers?.forEach((wrapper) => {
					const card = wrapper.querySelector('.extension-card');
					const name = card?.querySelector('h3')?.textContent?.toLowerCase() || '';
					const description = card?.querySelector('p')?.textContent?.toLowerCase() || '';
					const type = (card as HTMLElement)?.dataset.type || '';
					const tags = (card as HTMLElement)?.dataset.tags?.toLowerCase() || '';
					const categories = (wrapper as HTMLElement).dataset.categories?.split(',') || [];

					const matchesSearch = searchTerm === '' ||
						name.includes(searchTerm) ||
						description.includes(searchTerm) ||
						tags.includes(searchTerm);
					const matchesType = selectedType === '' || type === selectedType;
					const matchesCategory = selectedCategory === '' || categories.includes(selectedCategory);

					if (matchesSearch && matchesType && matchesCategory) {
						(wrapper as HTMLElement).style.display = '';
						visibleCount++;
					} else {
						(wrapper as HTMLElement).style.display = 'none';
					}
				});

				// Show/hide no results message
				if (noResults && extensionsGrid) {
					if (visibleCount === 0) {
						extensionsGrid.style.display = 'none';
						noResults.style.display = 'block';
					} else {
						extensionsGrid.style.display = 'grid';
						noResults.style.display = 'none';
					}
				}
			}

			// Add event listeners
			searchInput?.addEventListener('input', filterExtensions);
			typeFilter?.addEventListener('change', filterExtensions);
			categoryFilter?.addEventListener('change', filterExtensions);
		</script>
	</body>
</html>
