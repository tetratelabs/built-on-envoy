---
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ExtensionCard from '../components/ExtensionCard.astro';
import { parse } from 'yaml';
import fs from 'fs';
import path from 'path';

// Read all extension manifests
const extensionsDir = path.join(process.cwd(), '../extensions');
const extensionFolders = fs.readdirSync(extensionsDir)
	.filter(item => {
		const itemPath = path.join(extensionsDir, item);
		return fs.statSync(itemPath).isDirectory();
	});

interface Extension {
	name: string;
	version: string;
	category: string;
	author: string;
	description: string;
	longDescription: string;
	tags: string[];
	repository: string;
	license: string;
}

const extensions: Extension[] = extensionFolders
	.map(folder => {
		const manifestPath = path.join(extensionsDir, folder, 'manifest.yaml');
		if (!fs.existsSync(manifestPath)) return null;

		const manifestContent = fs.readFileSync(manifestPath, 'utf-8');
		const manifest = parse(manifestContent) as Extension;
		return manifest;
	})
	.filter((ext): ext is Extension => ext !== null)
	.sort((a, b) => a.name.localeCompare(b.name));

// Collect unique categories from extensions and sort alphabetically
const sortedCategories = [...new Set(extensions.map(ext => ext.category))]
	.sort((a, b) => a.localeCompare(b));
---

<!DOCTYPE html>
<html lang="en">
	<Head
		title="Extension Catalog - Envoy Ecosystem"
		description="Browse all available extensions for Envoy Proxy in the Envoy Ecosystem marketplace"
		additionalStylesheets={['/src/styles/extensions.css']}
		preventFOUC={true}
	/>
	<body>
		<Header />

		<main>
			<section class="page-hero">
				<div class="container">
					<h1>Extension Catalog</h1>
					<p class="hero-subtitle">
						Discover {extensions.length} community-maintained extensions for Envoy Proxy
					</p>

					<div class="filters">
						<div class="search-box">
							<input
								type="text"
								id="search-input"
								placeholder="Search extensions..."
								aria-label="Search extensions"
							/>
						</div>
						<div class="category-filter">
							<select id="category-filter" aria-label="Filter by category">
								<option value="">All Categories</option>
								{sortedCategories.map(category => (
									<option value={category}>{category}</option>
								))}
							</select>
						</div>
					</div>
				</div>
			</section>

			<section class="extensions-catalog">
				<div class="container">
					{extensions.length > 0 ? (
						<>
							<div class="extensions-grid" id="extensions-grid">
								{extensions.map(ext => (
									<ExtensionCard
										name={ext.name}
										category={ext.category}
										description={ext.description}
										href={`/extensions/${ext.name}`}
									/>
								))}
							</div>
							<div class="empty-state" id="no-results" style="display: none;">
								<p>No extensions found matching your search.</p>
							</div>
						</>
					) : (
						<div class="empty-state">
							<p>No extensions found. Check back soon!</p>
						</div>
					)}
				</div>
			</section>
		</main>

		<Footer />

		<script>
			// Prevent FOUC
			document.body.classList.add('loaded');

			// Extension filtering functionality
			const searchInput = document.getElementById('search-input') as HTMLInputElement;
			const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement;
			const extensionsGrid = document.getElementById('extensions-grid');
			const noResults = document.getElementById('no-results');

			function filterExtensions() {
				const searchTerm = searchInput?.value.toLowerCase() || '';
				const selectedCategory = categoryFilter?.value || '';

				const cards = extensionsGrid?.querySelectorAll('.extension-card-link, .extension-card');
				let visibleCount = 0;

				cards?.forEach((card) => {
					const name = card.querySelector('h3')?.textContent?.toLowerCase() || '';
					const description = card.querySelector('p')?.textContent?.toLowerCase() || '';
					const category = card.querySelector('.extension-badge')?.textContent || '';

					const matchesSearch = searchTerm === '' ||
						name.includes(searchTerm) ||
						description.includes(searchTerm);
					const matchesCategory = selectedCategory === '' || category === selectedCategory;

					if (matchesSearch && matchesCategory) {
						(card as HTMLElement).style.display = '';
						visibleCount++;
					} else {
						(card as HTMLElement).style.display = 'none';
					}
				});

				// Show/hide no results message
				if (noResults && extensionsGrid) {
					if (visibleCount === 0) {
						extensionsGrid.style.display = 'none';
						noResults.style.display = 'block';
					} else {
						extensionsGrid.style.display = 'grid';
						noResults.style.display = 'none';
					}
				}
			}

			// Add event listeners
			searchInput?.addEventListener('input', filterExtensions);
			categoryFilter?.addEventListener('change', filterExtensions);
		</script>
	</body>
</html>

