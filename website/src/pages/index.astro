---
import { PROJECT_NAME } from '../constants';
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import Extensions from '../components/Extensions.astro';
import CLIFeatures from '../components/CLIFeatures.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<!DOCTYPE html>
<html lang="en">
	<Head
		title={`${PROJECT_NAME} - Extensions Marketplace for Envoy Proxy`}
		description={`Discover, run, and build extensions for Envoy Proxy. A community-driven marketplace with zero-friction developer experience, powered by Tetrate`}
		preventFOUC={true}
	/>
	<body>
		<Header />

		<main>
			<Hero />
			<Features />
			<Extensions />
			<CLIFeatures />
			<CTA />
		</main>

		<Footer />

		<script>
			// Prevent FOUC
			document.body.classList.add('loaded');

			// Copy button functionality
			document.querySelectorAll('.copy-btn').forEach(btn => {
				btn.addEventListener('click', async () => {
					const codeBlock = btn.previousElementSibling;
					if (codeBlock) {
						await navigator.clipboard.writeText(codeBlock.textContent || '');
						const originalHTML = btn.innerHTML;
						btn.innerHTML = '✓';
						setTimeout(() => {
							btn.innerHTML = originalHTML;
						}, 2000);
					}
				});
			});
		</script>
	</body>
</html>
