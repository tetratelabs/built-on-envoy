---
import { PROJECT_NAME, CLI_NAME, GITHUB_REPO, EXTENSIONS_PATH } from '../../constants';
import Head from '../../components/Head.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { parse } from 'yaml';
import fs from 'fs';
import path from 'path';

export async function getStaticPaths() {
	const extensionsDir = path.join(process.cwd(), '../extensions');
	const extensionFolders = fs.readdirSync(extensionsDir)
		.filter(item => {
			const itemPath = path.join(extensionsDir, item);
			return fs.statSync(itemPath).isDirectory();
		});

	return extensionFolders.map(folder => {
		const manifestPath = path.join(extensionsDir, folder, 'manifest.yaml');
		if (!fs.existsSync(manifestPath)) return null;

		const manifestContent = fs.readFileSync(manifestPath, 'utf-8');
		const manifest = parse(manifestContent);

		return {
			params: { name: manifest.name },
			props: { extension: manifest }
		};
	}).filter(Boolean);
}

interface Example {
	title: string;
	description: string;
	code: string;
}

interface Extension {
	name: string;
	version: string;
	type: string;
	categories: string[];
	author: string;
	description: string;
	longDescription: string;
	tags: string[];
	license: string;
	examples?: Example[];
}

const { extension } = Astro.props as { extension: Extension };

// Helper function to format type names (snake_case to Title Case)
function formatTypeName(type: string): string {
	return type
		.split('_')
		.map(word => word.charAt(0).toUpperCase() + word.slice(1))
		.join(' ');
}
---

<!DOCTYPE html>
<html lang="en">
	<Head
		title={`${extension.name} - ${PROJECT_NAME}`}
		description={extension.description}
		additionalStylesheets={['/src/styles/extension-detail.css']}
		preventFOUC={true}
	/>
	<body>
		<Header />

		<main>
			<section class="extension-hero">
				<div class="container">
					<nav class="breadcrumb">
						<a href="/">Home</a>
						<span class="separator">→</span>
						<a href="/extensions">Extensions</a>
						<span class="separator">→</span>
						<span>{extension.name}</span>
					</nav>

					<div class="extension-header">
						<div class="extension-title-group">
							<h1>{extension.name}</h1>
							<span class={`extension-badge extension-badge--${extension.type}`}>{formatTypeName(extension.type)}</span>
						</div>
						<p class="extension-description">{extension.description}</p>
					</div>

					<div class="extension-meta">
						<div class="meta-item">
							<span class="meta-label">Version</span>
							<span class="meta-value">{extension.version}</span>
						</div>
						<div class="meta-item">
							<span class="meta-label">Author</span>
							<span class="meta-value">{extension.author}</span>
						</div>
						<div class="meta-item">
							<span class="meta-label">License</span>
							<span class="meta-value">{extension.license}</span>
						</div>
					</div>
				</div>
			</section>

			<section class="extension-content">
				<div class="container">
					<div class="content-grid">
						<div class="main-content">
							<section class="content-section">
								<h2>About</h2>
								<div class="long-description">
									{extension.longDescription.split('\n').map(para => para.trim() && <p>{para.trim()}</p>)}
								</div>
							</section>

							{extension.examples && extension.examples.length > 0 && (
								<section class="content-section">
									<h2>Usage Examples</h2>
									{extension.examples.map(example => (
										<div class="example-block">
											<h3>{example.title}</h3>
											<p class="example-description">{example.description}</p>
											<div class="code-block-wrapper">
												<pre class="code-block"><code>{example.code.trim()}</code></pre>
												<button class="copy-btn" aria-label="Copy code">📋</button>
											</div>
										</div>
									))}
								</section>
							)}

							<section class="content-section">
								<h2>Quick Start</h2>
								<div class="quick-start">
									<p>Get started with this extension in seconds:</p>
									<div class="code-block-wrapper">
										<pre class="code-block"><code>{CLI_NAME} run --plugin {extension.name}</code></pre>
										<button class="copy-btn" aria-label="Copy code">📋</button>
									</div>
								</div>
							</section>
						</div>

						<aside class="sidebar">
							<div class="sidebar-section">
								<h3>Categories</h3>
								<div class="categories">
									{extension.categories.map(category => (
										<span class="category">{category}</span>
									))}
								</div>
							</div>

							<div class="sidebar-section">
								<h3>Tags</h3>
								<div class="tags">
									{extension.tags.map(tag => (
										<span class="tag">{tag}</span>
									))}
								</div>
							</div>

							<div class="sidebar-section">
								<h3>Resources</h3>
								<ul class="resource-links">
									<li>
										<a href={`${GITHUB_REPO}/tree/main/${EXTENSIONS_PATH}/${extension.name}`} target="_blank" rel="noopener noreferrer">
											View on GitHub →
										</a>
									</li>
									<li>
										<a href="/extensions">← Back to Catalog</a>
									</li>
								</ul>
							</div>
						</aside>
					</div>
				</div>
			</section>
		</main>

		<Footer />

		<script>
			// Prevent FOUC
			document.body.classList.add('loaded');

			// Copy button functionality
			document.querySelectorAll('.copy-btn').forEach(btn => {
				btn.addEventListener('click', async () => {
					const codeBlock = btn.previousElementSibling;
					if (codeBlock) {
						await navigator.clipboard.writeText(codeBlock.textContent || '');
						const originalHTML = btn.innerHTML;
						btn.innerHTML = '✓';
						setTimeout(() => {
							btn.innerHTML = originalHTML;
						}, 2000);
					}
				});
			});
		</script>
	</body>
</html>

