---
import { PROJECT_NAME, GITHUB_REPO, EXTENSIONS_PATH } from '../../constants';
import Head from '../../components/Head.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { loadExtensions } from '../../utils/extensions';
import { marked } from 'marked';
import { createHighlighter } from 'shiki';
import '../../styles/extension-detail.css';

const highlighter = await createHighlighter({
	themes: ['github-dark'],
	langs: ['shell', 'bash', 'yaml', 'json', 'javascript', 'typescript', 'go', 'rust', 'plaintext'],
});

// Custom marked renderer that uses Shiki for code blocks
const renderer = new marked.Renderer();
renderer.code = function ({ text, lang }: { text: string; lang?: string }) {
	const language = lang || 'plaintext';
	try {
		return highlighter.codeToHtml(text, { lang: language, theme: 'github-dark' });
	} catch {
		// Fallback for unsupported languages
		return highlighter.codeToHtml(text, { lang: 'plaintext', theme: 'github-dark' });
	}
};
marked.use({ renderer });

export async function getStaticPaths() {
	const extensions = loadExtensions();

	return extensions.map(extension => ({
		params: { name: extension.name },
		props: { extension }
	}));
}

interface Example {
	title: string;
	description: string;
	code: string;
}

interface Extension {
	name: string;
	version: string;
	type: string;
	categories: string[];
	author: string;
	description: string;
	longDescription: string;
	tags: string[];
	license: string;
	composerVersion?: string;
	examples?: Example[];
	path: string;
}

const { extension } = Astro.props as { extension: Extension };

// Helper function to format type names (snake_case to Title Case)
function formatTypeName(type: string): string {
	return type
		.split('_')
		.map(word => word.charAt(0).toUpperCase() + word.slice(1))
		.join(' ');
}
---

<!DOCTYPE html>
<html lang="en">
	<Head
		title={`${extension.name} - ${PROJECT_NAME}`}
		description={extension.description}
		preventFOUC={true}
	/>
	<body>
		<Header />

		<main>
			<section class="extension-hero">
				<div class="container">
					<nav class="breadcrumb">
						<a href="/">Home</a>
						<span class="separator">→</span>
						<a href="/extensions">Extensions</a>
						<span class="separator">→</span>
						<span>{extension.name}</span>
					</nav>

					<div class="extension-header">
						<div class="extension-header-left">
							<h1>{extension.name}</h1>
							<div class="extension-meta">
								<div class="meta-item">
									<span class="meta-label">Type</span>
									<span class={`extension-badge extension-badge--${extension.type}`}>{formatTypeName(extension.type)}</span>
								</div>
								<div class="meta-item">
									<span class="meta-label">Version</span>
									<span class="meta-value">{extension.version}</span>
								</div>
								{extension.type === 'composer' && extension.composerVersion && (
									<div class="meta-item">
										<span class="meta-label">Composer</span>
										<span class="meta-value">{extension.composerVersion}</span>
									</div>
								)}
								<div class="meta-item">
									<span class="meta-label">Author</span>
									<span class="meta-value">{extension.author}</span>
								</div>
								<div class="meta-item">
									<span class="meta-label">License</span>
									<span class="meta-value">{extension.license}</span>
								</div>
							</div>
						</div>
						<p class="extension-description">{extension.description}</p>
					</div>
				</div>
			</section>

			<section class="extension-content">
				<div class="container">
					<div class="content-grid">
						<div class="main-content">
							<section class="content-section">
								<h2>About</h2>
								<div class="long-description prose" set:html={marked.parse(extension.longDescription)} />
							</section>

							{extension.examples && extension.examples.length > 0 && (
								<section class="content-section">
									<h2>Usage Examples</h2>
									{extension.examples.map(example => (
										<div class="example-block">
											<h3>{example.title}</h3>
											<div class="example-description prose" set:html={marked.parse(example.description)} />
											<div class="code-block-wrapper">
												<Fragment set:html={highlighter.codeToHtml(example.code.trim(), { lang: 'shell', theme: 'github-dark' })} />
												<button class="copy-btn" aria-label="Copy code">
													<svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
														<path d="M5.5 2.5h-3v11h7v-3m-4-8h7v7h-7v-7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
													</svg>
												</button>
											</div>
										</div>
									))}
								</section>
							)}
						</div>

						<aside class="sidebar">
							<div class="sidebar-section">
								<h3>Categories</h3>
								<div class="categories">
									{extension.categories.map(category => (
										<span class="category">{category}</span>
									))}
								</div>
							</div>

							<div class="sidebar-section">
								<h3>Tags</h3>
								<div class="tags">
									{extension.tags.map(tag => (
										<span class="tag">{tag}</span>
									))}
								</div>
							</div>

							<ul class="resource-links">
								<li>
									<a href="/extensions">← Catalog</a>
								</li>
								<li>
									<a href={`${GITHUB_REPO}/tree/main/${EXTENSIONS_PATH}/${extension.path}`} target="_blank" rel="noopener noreferrer">
										GitHub →
									</a>
								</li>
							</ul>
						</aside>
					</div>
				</div>
			</section>
		</main>

		<Footer />

		<script>
			// Prevent FOUC
			document.body.classList.add('loaded');

			// Copy button functionality
			document.querySelectorAll('.copy-btn').forEach(btn => {
				btn.addEventListener('click', async () => {
					const codeBlock = btn.previousElementSibling;
					if (codeBlock) {
						await navigator.clipboard.writeText(codeBlock.textContent || '');
						const originalHTML = btn.innerHTML;
						btn.innerHTML = '✓';
						setTimeout(() => {
							btn.innerHTML = originalHTML;
						}, 2000);
					}
				});
			});
		</script>
	</body>
</html>

