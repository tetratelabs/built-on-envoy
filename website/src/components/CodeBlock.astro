---
import { CLI_NAME } from '../constants';

interface Props {
	lang?: string;
	code: string;
}

const { lang = 'bash', code } = Astro.props;
// Replace the placeholder with the actual CLI name
const content = code.replace(/\{\{CLI_NAME\}\}/g, CLI_NAME);
---

<pre><code class={`language-${lang}`} set:text={content} /></pre>
