---
import { CLI_NAME, GITHUB_REPO_RAW } from '../constants';
---

<section class="features">
	<div class="container">
		<div class="feature-grid">
			<div class="feature-card">
				<h3><span class="feature-icon">★</span>&nbsp;&nbsp;Discover</h3>
				<p>Discover the community extensions you can start using today.</p>
				<div class="code-example">
					<code>{CLI_NAME} list</code>
				</div>
				<div class="code-output">
					<span class="output-info">→</span>&nbsp;Available extensions:<br/>
					<span class="output-muted">NAME         VERSION  TYPE
cache        1.3.0    dynamic_module
transformer  1.2.0    lua</span>
				</div>
			</div>

			<div class="feature-card">
				<h3><span class="feature-icon">▶</span>&nbsp;&nbsp;Run</h3>
				<p>Start Envoy with extensions in a single command.</p>
				<div class="code-example">
					<code>{CLI_NAME} run --extension cache</code>
				</div>
				<div class="code-output">
					<span class="output-success">✓</span> Starting Envoy 1.37.0...<br/>
					<span class="output-info">→</span> <span class="output-link">http://localhost:10000</span><br/>
					<span class="output-muted">Test with:<br/>curl http://localhost:10000/</span>
				</div>
			</div>

			<div class="feature-card">
				<h3><span class="feature-icon">⤴</span>&nbsp;&nbsp;Build & Share</h3>
				<p>Build and publish your extension to the ecosystem.</p>
				<div class="code-example">
					<code>{CLI_NAME} extension push ./my-extension</code>
				</div>
				<div class="code-output">
					<span class="output-success">✓</span> Extension validated<br/>
					<span class="output-info">→</span> Opening pull request...<br/>
					<span class="output-link">github.com/{GITHUB_REPO_RAW}/pulls/42</span>
				</div>
			</div>
		</div>
	</div>
</section>
