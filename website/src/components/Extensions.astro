---
import ExtensionCard from './ExtensionCard.astro';
import { loadExtensions } from '../utils/extensions';

const featuredExtensions = loadExtensions().filter(ext => ext.featured === true);
---

<section class="extensions" id="extensions">
	<div class="container">
		<h2>Featured Extensions</h2>
		<p class="section-subtitle">A curated and officially maintained list of extensions ready to use</p>

		<div class="extensions-grid">
			{featuredExtensions.map(ext => (
				<ExtensionCard
					name={ext.name}
					type={ext.type}
					description={ext.description}
					href={`/extensions/${ext.name}`}
					tags={ext.tags}
				/>
			))}
		</div>

		<div class="browse-all">
			<a href="/extensions" class="btn-secondary">
				Browse All Extensions →
			</a>
		</div>
	</div>
</section>
