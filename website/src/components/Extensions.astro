<section class="extensions" id="extensions">
	<div class="container">
		<h2>Featured Extensions</h2>
		<p class="section-subtitle">Community-maintained extensions ready to use</p>

		<div class="extensions-grid">
			<div class="extension-card">
				<div class="extension-header">
					<h3>rate-limiter</h3>
					<span class="extension-badge">Popular</span>
				</div>
				<p>Token bucket rate limiting with Redis backend support</p>
				<div class="extension-footer">
					<code>ee run --plugin rate-limiter</code>
				</div>
			</div>

			<div class="extension-card">
				<div class="extension-header">
					<h3>auth-jwt</h3>
					<span class="extension-badge">Security</span>
				</div>
				<p>JWT authentication and validation with JWKS endpoint support</p>
				<div class="extension-footer">
					<code>ee run --plugin auth-jwt</code>
				</div>
			</div>

			<div class="extension-card">
				<div class="extension-header">
					<h3>cors</h3>
					<span class="extension-badge">Network</span>
				</div>
				<p>Configurable CORS policy with wildcard and regex support</p>
				<div class="extension-footer">
					<code>ee run --plugin cors</code>
				</div>
			</div>

			<div class="extension-card">
				<div class="extension-header">
					<h3>request-logger</h3>
					<span class="extension-badge">Observability</span>
				</div>
				<p>Advanced request/response logging with custom formatters</p>
				<div class="extension-footer">
					<code>ee run --plugin request-logger</code>
				</div>
			</div>

			<div class="extension-card">
				<div class="extension-header">
					<h3>transform-headers</h3>
					<span class="extension-badge">Transform</span>
				</div>
				<p>Add, modify, or remove headers with templating support</p>
				<div class="extension-footer">
					<code>ee run --plugin transform-headers</code>
				</div>
			</div>

			<div class="extension-card">
				<div class="extension-header">
					<h3>cache</h3>
					<span class="extension-badge">Performance</span>
				</div>
				<p>HTTP caching with TTL control and cache key customization</p>
				<div class="extension-footer">
					<code>ee run --plugin cache</code>
				</div>
			</div>
		</div>

		<div class="browse-all">
			<a href="/extensions" class="btn-secondary">
				Browse All Extensions →
			</a>
		</div>
	</div>
</section>
