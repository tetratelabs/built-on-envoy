---
interface Props {
	name: string;
	type: string;
	categories: string[];
	description: string;
	href: string;
	tags?: string[];
}

const { name, type, categories, description, href, tags = [] } = Astro.props;
const sortedCategories = [...categories].sort((a, b) => a.localeCompare(b));
const sortedTags = [...tags].sort((a, b) => a.localeCompare(b));
---

<a href={href} class="extension-card-link">
	<div class="extension-card" data-type={type} data-tags={tags.join(',')}>
		<div class="extension-header">
			<h3>{name}</h3>
			<div class="extension-badges">
				{sortedCategories.map(category => (
					<span class={`extension-badge extension-badge--${category.toLowerCase().replace(/\s+/g, '-')}`}>{category}</span>
				))}
			</div>
		</div>
		<p>{description}</p>
		{tags.length > 0 && (
			<div class="extension-tags">
				{sortedTags.map(tag => (
					<span class="extension-tag">{tag}</span>
				))}
			</div>
		)}
	</div>
</a>
