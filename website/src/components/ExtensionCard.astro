---
interface Props {
	name: string;
	type: string;
	categories: string[];
	description: string;
	href: string;
	parent?: string;
	tags?: string[];
	filterTypes?: string[];
}

const { name, type, categories, description, href, parent, tags = [], filterTypes = [] } = Astro.props;
const sortedCategories = [...categories].sort((a, b) => a.localeCompare(b));
const sortedTags = [...tags].sort((a, b) => a.localeCompare(b));
---

<div class="extension-card" data-type={type} data-tags={tags.join(',')} data-filter-types={filterTypes.join(',')}>
	<div class="extension-header">
		<div class="extension-title">
			<h3><a href={href} class="extension-card-primary-link">{name}</a></h3>
			{parent && <a href={`/extensions/sets/${parent}`} class="extension-parent extension-parent-link">bundle: {parent}</a>}
		</div>
		<div class="extension-badges">
			{sortedCategories.map(category => (
				<span class={`extension-badge extension-badge--${category.toLowerCase().replace(/\s+/g, '-')}`}>{category}</span>
			))}
		</div>
	</div>
	<p>{description}</p>
	{tags.length > 0 && (
		<div class="extension-tags">
			{sortedTags.map(tag => (
				<span class="extension-tag">{tag}</span>
			))}
		</div>
	)}
</div>
