---
interface Props {
	name: string;
	type: string;
	description: string;
	href: string;
	tags?: string[];
}

const { name, type, description, href, tags = [] } = Astro.props;

// Helper function to format type names (snake_case to Title Case)
function formatTypeName(t: string): string {
	return t
		.split('_')
		.map(word => word.charAt(0).toUpperCase() + word.slice(1))
		.join(' ');
}
---

<a href={href} class="extension-card-link">
	<div class="extension-card" data-type={type} data-tags={tags.join(',')}>
		<div class="extension-header">
			<h3>{name}</h3>
			<span class={`extension-badge extension-badge--${type}`}>{formatTypeName(type)}</span>
		</div>
		<p>{description}</p>
		{tags.length > 0 && (
			<div class="extension-tags">
				{tags.map(tag => (
					<span class="extension-tag">{tag}</span>
				))}
			</div>
		)}
	</div>
</a>
