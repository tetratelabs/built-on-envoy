---
import { PROJECT_NAME } from '../constants';
import Head from '../components/Head.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import '../styles/docs.css';

interface Props {
	frontmatter?: {
		title: string;
		description?: string;
	};
	title?: string;
	description?: string;
}

// Support both direct props (from .astro files) and frontmatter (from .mdx files)
const { frontmatter } = Astro.props;
const title = frontmatter?.title ?? Astro.props.title;
const description = frontmatter?.description ?? Astro.props.description;
---

<!DOCTYPE html>
<html lang="en">
	<Head
		title={`${title} | ${PROJECT_NAME}`}
		description={description}
	/>
	<body>
		<Header />

		<div class="docs-container">
			<Sidebar yamlPaths={[
				"src/pages/docs/sidebar-static.yaml",
				"src/pages/docs/sidebar-cli.yaml"
			]} />

			<main class="docs-main">
				<article class="prose">
					<slot />
				</article>
			</main>
		</div>

		<Footer />
	</body>
</html>
