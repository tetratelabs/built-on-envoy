{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tetratelabs/built-on-envoy/extensions/manifest.schema.json",
  "title": "Extension Manifest",
  "description": "Schema for Built On Envoy extension manifest files",
  "type": "object",
  "required": [
    "name",
    "version",
    "categories",
    "author",
    "description",
    "longDescription",
    "type",
    "tags",
    "license",
    "examples"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique identifier for the extension",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "version": {
      "type": "string",
      "description": "Semantic version of the extension",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "categories": {
      "type": "array",
      "description": "Functional categories of the extension",
      "items": {
        "type": "string",
        "enum": [
          "AI",
          "Network",
          "Observability",
          "Performance",
          "Transform",
          "Security"
        ]
      }
    },
    "author": {
      "type": "string",
      "description": "Author or organization name",
      "minLength": 1
    },
    "featured": {
      "type": "boolean",
      "description": "Whether to feature this extension in UI/listings"
    },
    "description": {
      "type": "string",
      "description": "Short single-line description of the extension",
      "minLength": 1,
      "maxLength": 200
    },
    "longDescription": {
      "type": "string",
      "description": "Detailed multi-line description with markdown support",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "description": "Type of the extension",
      "enum": [
        "lua",
        "wasm",
        "dynamic_module",
        "composer"
      ]
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags for categorization",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-z][a-z0-9-]*$"
      }
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier",
      "minLength": 1
    },
    "examples": {
      "type": "array",
      "description": "Usage examples for the extension",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "title",
          "description",
          "code"
        ],
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "description": "Short title for the example",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "Explanation of what the example demonstrates",
            "minLength": 1
          },
          "code": {
            "type": "string",
            "description": "Code snippet showing usage",
            "minLength": 1
          }
        }
      }
    }
  }
}
