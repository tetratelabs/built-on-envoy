{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tetratelabs/built-on-envoy/extensions/manifest.schema.json",
  "title": "Extension Manifest",
  "description": "Schema for Built On Envoy extension manifest files.",
  "type": "object",
  "required": [
    "name",
    "categories",
    "author",
    "description",
    "longDescription",
    "type",
    "tags",
    "license",
    "examples"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique identifier for the extension.",
      "minLength": 1,
      "pattern": "^[a-z][.a-z0-9-_]*$"
    },
    "version": {
      "type": "string",
      "description": "Semantic version of the extension. Required unless the `parent` field is set.",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-dev)?$"
    },
    "minEnvoyVersion": {
      "type": "string",
      "description": "Minimum compatible Envoy version.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "maxEnvoyVersion": {
      "type": "string",
      "description": "Maximum compatible Envoy version.",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "categories": {
      "type": "array",
      "description": "Functional categories of the extension.",
      "items": {
        "type": "string",
        "enum": [
          "AI",
          "Authentication",
          "Decoder",
          "Examples",
          "Misc",
          "Network",
          "Observability",
          "Performance",
          "Traffic Control",
          "Transform",
          "Security"
        ]
      }
    },
    "author": {
      "type": "string",
      "description": "Author or organization name.",
      "minLength": 1
    },
    "featured": {
      "type": "boolean",
      "description": "Whether to feature this extension in UI/listings."
    },
    "description": {
      "type": "string",
      "description": "Short single-line description of the extension.",
      "minLength": 1,
      "maxLength": 200
    },
    "longDescription": {
      "type": "string",
      "description": "Detailed multi-line description with markdown support.",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "description": "Type of the extension.",
      "enum": [
        "lua",
        "wasm",
        "rust",
        "go",
        "composer",
        "ext_proc"
      ]
    },
    "filterType": {
      "type": "string",
      "description": "Envoy filter type. Defaults to `http` if not specified.",
      "enum": [
        "http",
        "network",
        "listener",
        "udp_listener"
      ],
      "default": "http"
    },
    "composerVersion": {
      "type": "string",
      "description": "Version of Built On Envoy Composer. Required if type is `composer` unless the `parent` field is set.",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-dev)?$"
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags for categorization.",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "pattern": "^[a-z][a-z0-9-]*$"
      }
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier.",
      "minLength": 1
    },
    "examples": {
      "type": "array",
      "description": "Usage examples for the extension.",
      "minItems": 0,
      "items": {
        "type": "object",
        "required": [
          "title",
          "description",
          "code"
        ],
        "additionalProperties": false,
        "properties": {
          "title": {
            "type": "string",
            "description": "Short title for the example.",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "description": "Explanation of what the example demonstrates.",
            "minLength": 1
          },
          "code": {
            "type": "string",
            "description": "Code snippet showing usage.",
            "minLength": 1
          }
        }
      }
    },
    "lua": {
      "type": "object",
      "description": "Lua extension configuration.",
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "description": "Path to the Lua script file.",
          "minLength": 1
        },
        "inline": {
          "type": "string",
          "description": "Inline Lua script code.",
          "minLength": 1
        }
      },
      "oneOf": [
        { "required": ["path"] },
        { "required": ["inline"] }
      ]
    },
    "extProc": {
      "type": "object",
      "description": "External processor (ext_proc) configuration.",
      "additionalProperties": false,
      "properties": {
        "grpcPort": {
          "type": "integer",
          "description": "Port the ext_proc gRPC server listens on.",
          "default": 50051
        },
        "failureModeAllow": {
          "type": "boolean",
          "description": "Whether to allow requests through if the ext_proc server is unavailable or times out."
        },
        "messageTimeout": {
          "type": "string",
          "description": "Per-message timeout (e.g. '200ms'). Envoy waits this long for each ProcessingResponse."
        },
        "processingMode": {
          "type": "object",
          "description": "Controls which HTTP phases are forwarded to the ext_proc server.",
          "additionalProperties": false,
          "properties": {
            "requestHeaderMode": {
              "type": "string",
              "description": "Whether to send request headers to the processor.",
              "enum": ["SEND", "SKIP", "DEFAULT"]
            },
            "responseHeaderMode": {
              "type": "string",
              "description": "Whether to send response headers to the processor.",
              "enum": ["SEND", "SKIP", "DEFAULT"]
            },
            "requestBodyMode": {
              "type": "string",
              "description": "How to send the request body to the processor.",
              "enum": ["NONE", "BUFFERED", "STREAMED", "BUFFERED_PARTIAL"]
            },
            "responseBodyMode": {
              "type": "string",
              "description": "How to send the response body to the processor.",
              "enum": ["NONE", "BUFFERED", "STREAMED", "BUFFERED_PARTIAL"]
            }
          }
        }
      }
    },
    "parent": {
      "type": "string",
      "description": "Parent extension set whose version will be used. When set, the `version` and `composerVersion` fields can't be set.",
      "minLength": 1,
      "pattern": "^[a-z][a-z0-9-_.]*$"
    },
    "extensionSet": {
      "type": "boolean",
      "description": "Whether this manifest defines a set of extensions."
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "type": { "const": "lua" }
        }
      },
      "then": {
        "required": ["lua"]
      },
      "else": {
        "properties": {
          "lua": false
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": { "const": "ext_proc" }
        }
      },
      "then": {
        "required": ["extProc"]
      },
      "else": {
        "properties": {
          "extProc": false
        }
      }
    },
    {
      "if": {
        "required": ["parent"]
      },
      "then": {
        "properties": {
          "type": { "const": "go" },
          "version": false,
          "composerVersion": false
        }
      }
    },
    {
      "if": {
        "not": {
          "required": ["parent"]
        }
      },
      "then": {
        "required": ["version"]
      }
    },
    {
      "if": {
        "allOf": [
          {
            "properties": {
              "type": { "const": "go" }
            }
          },
          {
            "not": {
              "required": ["parent"]
            }
          }
        ]
      },
      "then": {
        "required": ["composerVersion"]
      }
    }
  ]
}
