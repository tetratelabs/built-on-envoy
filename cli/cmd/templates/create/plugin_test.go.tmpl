// Tests for customHttpFilterFactory.Create (per-route config override)

func Test_PerRouteConfigOverride(t *testing.T) {
	baseConfig := &customHttpFilterConfig{HeaderValue: "global"}
	baseFactory := &customHttpFilterFactory{config: baseConfig}

	t.Run("per-route config overrides factory config", func(t *testing.T) {
		ctrl := gomock.NewController(t)
		defer ctrl.Finish()

		perRoute := &customHttpFilterConfig{HeaderValue: "per-route"}
		handle := newFilterHandleWithPerRouteConfig(ctrl, perRoute)
		filter := baseFactory.Create(handle)

		f, ok := filter.(*customHttpFilter)
		require.True(t, ok)
		require.Equal(t, "per-route", f.config.HeaderValue)
	})

	t.Run("nil per-route config uses factory config", func(t *testing.T) {
		ctrl := gomock.NewController(t)
		defer ctrl.Finish()

		handle := newFilterHandleWithoutPerRouteConfig(ctrl)
		filter := baseFactory.Create(handle)

		f, ok := filter.(*customHttpFilter)
		require.True(t, ok)
		require.Equal(t, "global", f.config.HeaderValue)
	})

	t.Run("wrong type per-route config uses factory config", func(t *testing.T) {
		ctrl := gomock.NewController(t)
		defer ctrl.Finish()

		handle := newFilterHandleWithPerRouteConfig(ctrl, "not-a-config")
		filter := baseFactory.Create(handle)

		f, ok := filter.(*customHttpFilter)
		require.True(t, ok)
		require.Equal(t, "global", f.config.HeaderValue)
	})
}

// Tests for customHttpFilter.OnRequestHeaders

func Test_OnRequestHeaders(t *testing.T) {
	t.Run("adds header with config value", func(t *testing.T) {
		ctrl := gomock.NewController(t)
		defer ctrl.Finish()

		handle := newFilterHandleWithoutPerRouteConfig(ctrl)
		filter := &customHttpFilter{
			handle: handle,
			config: &customHttpFilterConfig{HeaderValue: "test-value"},
		}

		headers := fake.NewFakeHeaderMap(map[string][]string{})
		status := filter.OnRequestHeaders(headers, false)

		require.Equal(t, shared.HeadersStatusContinue, status)
		require.Equal(t, "test-value", headers.GetOne("x-{{ .Name }}").ToUnsafeString())
	})

	t.Run("per-route config value is used", func(t *testing.T) {
		ctrl := gomock.NewController(t)
		defer ctrl.Finish()

		perRoute := &customHttpFilterConfig{HeaderValue: "per-route-value"}
		handle := newFilterHandleWithPerRouteConfig(ctrl, perRoute)
		factory := &customHttpFilterFactory{config: &customHttpFilterConfig{HeaderValue: "global-value"}}
		filter := factory.Create(handle).(*customHttpFilter)

		headers := fake.NewFakeHeaderMap(map[string][]string{})
		status := filter.OnRequestHeaders(headers, false)

		require.Equal(t, shared.HeadersStatusContinue, status)
		require.Equal(t, "per-route-value", headers.GetOne("x-{{ .Name }}").ToUnsafeString())
	})
}

